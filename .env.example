# --- Required: at least one ---
# Anthropic (default — Claude Sonnet 4.5 is recommended)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI (used as fallback if ANTHROPIC_API_KEY is missing)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Optional: LangSmith observability (bonus item, +4) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=contract-lens
